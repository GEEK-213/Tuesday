# ============================================
# Tuesday AI Agent - .gitignore
# ============================================
# This file tells Git which files to IGNORE
# (i.e., never upload to GitHub).
# ============================================

# ---------- API KEYS & SECRETS ----------
# This is the MOST important section.
# NEVER upload files containing passwords or API keys.
.env
.env.local
.env.production
.env.*.local
secrets/
*.key
*.pem

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg
.Python
venv/
env/
.venv/

# ---------- Node.js ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------- IDE / Editor ----------
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- OS Files ----------
Desktop.ini
ehthumbs.db

# ---------- Logs & Databases ----------
logs/
*.log
*.sqlite3
*.db

# ---------- Model Files ----------
# Large AI model files should NOT be in Git
models/local/*.bin
models/local/*.gguf
models/local/*.safetensors
models/local/*.pt
models/local/*.onnx
