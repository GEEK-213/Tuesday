# ============================================
# Tuesday AI Agent — Environment Variables
# ============================================
# 1. Copy this file:  copy .env.example .env
# 2. Fill in your real keys in the .env file
# 3. NEVER commit .env to Git!
# ============================================

# ---- Google Gemini API Keys (Round-Robin Rotation) ----
# Get free keys at: https://aistudio.google.com/apikey
# We use multiple keys to spread out free-tier rate limits.
GEMINI_KEY_1=your-gemini-key-1-here
GEMINI_KEY_2=your-gemini-key-2-here
GEMINI_KEY_3=your-gemini-key-3-here
GEMINI_KEY_4=your-gemini-key-4-here
GEMINI_KEY_5=your-gemini-key-5-here

# ---- Groq API Key (Lightning Fast Inference) ----
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ---- General ----
TUESDAY_DEBUG=false
TUESDAY_LOG_LEVEL=INFO
